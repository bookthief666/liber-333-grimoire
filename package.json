{
  "name": "liber-333-grimoire",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:gematria": "node --test tests/gematriaEngine.test.mjs",
    "test:journal": "node --test tests/journalStorage.test.mjs",
    "test:rites": "node --test tests/ritualData.test.mjs",
    "test:correspondences": "node --test tests/correspondences.test.mjs",
    "test:oracle": "node --test tests/oraclePrompts.test.mjs",
    "test:oracle-request": "node --test tests/oracleRequest.test.mjs",
    "test:oracle-rate-limit": "node --test tests/oracleRateLimit.test.mjs",
    "test:chapters": "node --test tests/liber333Data.test.mjs",
    "test:cosmic": "node --test tests/cosmicTiming.test.mjs",
    "test:tree": "node --test tests/treeModel.test.mjs",
    "test:selection": "node --test tests/divinationSelection.test.mjs",
    "test:provenance": "node --test tests/provenance.test.mjs",
    "test:unit": "npm run test:gematria && npm run test:journal && npm run test:rites && npm run test:correspondences && npm run test:oracle && npm run test:oracle-request && npm run test:oracle-rate-limit && npm run test:chapters && npm run test:cosmic && npm run test:tree && npm run test:selection && npm run test:provenance",
    "validate:release": "node scripts/validate-release.mjs",
